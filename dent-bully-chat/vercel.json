{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/widget\\.js",
      "dest": "/widget.js"
    },
    {
      "src": "/widget\\.css",
      "dest": "/widget.css"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
